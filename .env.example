DB_USERNAME=immich
DB_PASSWORD=
DB_DATABASE_NAME=immich
DB_DATA_LOCATION=/data/immich/postgres        # local SSD path — never NFS, never a Docker NFS volume

NAS_IP=192.168.0.134
NAS_THUMBS_PATH=/Docker/photo-search/thumbs   # NFS export path on the NAS

IMMICH_MACHINE_LEARNING_URL=http://<gpu-ml-host-ip>:3003

LANDMARK_MATCH_THRESHOLD=0.75

# ── Search agent (search-api) ──────────────────────────────────────────────
# The tool-calling Claude agent that drives natural-language search.
# Without ANTHROPIC_API_KEY, search-api still works but uses only the
# rule-based fallback parser (less precise).
# Commercial API terms (no training on data, ~7-day abuse-screening retention)
# apply to API keys — distinct from consumer claude.ai plans. Re-verify before
# committing; see project README.
ANTHROPIC_API_KEY=

# Models are PINNED, not auto-"latest" — move deliberately, then re-run the
# structured test list. Two vars so the SQL step can escalate independently of
# the orchestrator (today both default to Haiku in config.py).
# Escalation target as of 2026-07: claude-sonnet-5. Haiku's date suffix is
# mandatory ("claude-haiku-4-5" alone is not a valid id).
# AGENT_MODEL=claude-haiku-4-5-20251001
# SQL_MODEL=claude-haiku-4-5-20251001

# Loop bounds. AGENT_WALL_CLOCK_TIMEOUT MUST stay below search-api's Gunicorn
# --timeout (90s) so it fires first and degrades into the rules fallback
# rather than Gunicorn killing the worker.
# AGENT_MAX_TURNS=6
# AGENT_WALL_CLOCK_TIMEOUT=60

# Toggle the raw-SQL tool. Keep FALSE until the read-only Postgres role exists
# and SQL_READONLY_DSN is set (prove the loop + search_photos first).
AGENT_SQL_ENABLED=false

# ── SQL tool (run_readonly_sql) ────────────────────────────────────────────
# Connects as the DEDICATED read-only role from sql/create_readonly_role.sql —
# NOT the Immich superuser. This DSN is the real security boundary. Leave empty
# until the role is created; required only when AGENT_SQL_ENABLED=true.
SQL_READONLY_DSN=
# SQL_READONLY_DSN=postgresql://immich_search_ro:CHANGE_ME@postgres:5432/immich

# Optional tunables (defaults in config.py):
# SQL_ROW_CAP=100
# SQL_STATEMENT_TIMEOUT_MS=5000
